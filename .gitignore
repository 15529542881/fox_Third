# Unity 通用忽略规则
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# 捕获所有.meta文件，但跟踪特定的.meta文件
*.meta
!*.prefab.meta
!*.mat.meta
!*.asset.meta
!*.scene.meta
!*.fbx.meta
!*.png.meta
!*.jpg.meta

# Unity Package Manager
/Packages/Manifest.json.meta
/Packages/packages-lock.json
/Packages/packages-lock.json.meta

# 构建报告
/*.apk
/*.aab
/*.unitypackage
/*.zip

# 其他缓存
/[Mm]emoryCaptures/
/[Vv]endor/